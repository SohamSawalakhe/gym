# ==========================================
# FITFLOW SaaS - Environment Configurations
# ==========================================

# 1. DATABASE (Prisma PostgreSQL Connection)
# Replace with your actual PostgreSQL connection string.
# Example: postgresql://username:password@localhost:5432/gym_saas?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fitflow?schema=public"

# 2. SECURITY & AUTHENTICATION
# A secure random string used to sign JWT authentication cookies.
# You can generate a strong secret via: openssl rand -base64 32
JWT_SECRET="fitflow-saas-super-secret-jwt-key-2026-secure-token"

# 3. GEMINI AI (RAG Chatbot Assistant)
# Required to enable the Retrieval-Augmented Generation mode for the chatbot.
# Get a free key at Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY="AIzaSyYourActualGeminiApiKeyGoesHere"

# 4. BACKGROUND SCHEDULER & DISPATCHER
# Security token to prevent unauthorized triggers of your renewal crons.
# When setting up Vercel Crons or GitHub Actions, pass this as a Bearer token.
CRON_SECRET="fitflow-scheduler-cron-secret-token-protection"

# 5. PAYMENT GATEWAYS (Global Fallback Defaults)
# Optional. Gym owners enter their own Razorpay keys in Settings, 
# but these serve as global developer fallbacks for testing.
RAZORPAY_KEY_ID="rzp_test_mockKeyId12345"
RAZORPAY_KEY_SECRET="mockSecretValue12345"

# 6. WHATSAPP BUSINESS CLOUD API INTEGRATION
# The system utilizes Meta's official Cloud API which supports dynamic multi-tenancy.
# * Gym owners configure their own individual credentials dynamically via the Settings UI 
#   (their Phone Number ID & Access Token are securely saved in their database WhatsappSession row).
# * The "Verify Token" requested by the Meta Developer Console during the Webhook configuration 
#   corresponds to your JWT_SECRET (above).

# 7. META EMBEDDED SIGNUP (One-Click Onboarding)
# Optional. Provide these system-wide Meta App settings to enable one-click 
# "Connect via Meta Quick Setup" popups directly on your clients' Settings page.
NEXT_PUBLIC_FACEBOOK_APP_ID="your-facebook-app-id-here"
NEXT_PUBLIC_FB_SIGNUP_CONFIG_ID="your-embedded-signup-login-configuration-id-here"
FACEBOOK_APP_SECRET="your-facebook-app-secret-here"


